  "keyFeatures": [
    "Connect to pre-certified Stripe Terminal card readers via Bluetooth, USB, Internet, or Tap to Pay",
    "Collect in-person card payments with full PaymentIntent lifecycle management",
    "Support for offline payments with automatic forwarding when back online",
    "Save payment methods for future use via SetupIntents",
    "Process refunds directly through the terminal reader",
    "Collect custom inputs (signatures, phone, email, numeric, text) on the reader display",
    "Reader software update management with progress tracking",
    "EasyConnect API for simplified reader discovery and connection",
    "Tap to Pay on iPhone and Android with customizable UX configuration",
    "Collect NFC UID and magstripe data with CollectData API"
  ],
